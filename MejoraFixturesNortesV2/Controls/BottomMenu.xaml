<ContentView
    x:Class="MejoraFixturesNortesV2.Controls.BottomMenu"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid BackgroundColor="White"
          HeightRequest="75"
          ColumnDefinitions="*,*,*,*"
          Padding="0,5">

        <!-- Catalogo -->
        <VerticalStackLayout HorizontalOptions="Center" Spacing="3">
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCatalogoTapped"/>
            </VerticalStackLayout.GestureRecognizers>

            <Image Source="fixturecatalogo.png" HeightRequest="25"/>
            <Label Text="Catalogo" FontSize="12" TextColor="#0D3B66"/>
        </VerticalStackLayout>

        <!-- Auditorias -->
        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="3">
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnAuditoriasTapped"/>
            </VerticalStackLayout.GestureRecognizers>

            <Image Source="calendario.png" HeightRequest="25"/>
            <Label Text="Auditorias" FontSize="12" TextColor="#0D3B66"/>
        </VerticalStackLayout>

        <!-- Reportes -->
        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="3">
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnReportesTapped"/>
            </VerticalStackLayout.GestureRecognizers>

            <Image Source="reportes.png" HeightRequest="25"/>
            <Label Text="Reportes" FontSize="12" TextColor="#0D3B66"/>
        </VerticalStackLayout>

        <!-- Perfil -->
        <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="3">
            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnPerfilTapped"/>
            </VerticalStackLayout.GestureRecognizers>

            <Image Source="catalogousuario.png" HeightRequest="25"/>
            <Label Text="Perfil" FontSize="12" TextColor="#0D3B66"/>
        </VerticalStackLayout>

    </Grid>

</ContentView>