<ContentPage
    x:Class="MejoraFixturesNortesV2.Views.DanosPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Reporte de Daño"
    BackgroundColor="White">

    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="20">

            <Label
                Text="Reporte de Fixture Dañada"
                FontSize="22"
                FontAttributes="Bold"
                TextColor="#0D3B66"/>

            <!-- SERIAL -->
            <Entry
                x:Name="SerialEntry"
                Placeholder="Escanea o escribe el serial"
                BackgroundColor="#F5F5F5"/>

            <!-- 🔍 BOTON ESCANEAR CON ICONO -->
            <Frame
                CornerRadius="20"
                BackgroundColor="#0D3B66"
                Padding="15"
                HasShadow="False">

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">

                    <Image
                        Source="elescaneo.png"
                        HeightRequest="26"
                        WidthRequest="26"
                        VerticalOptions="Center"/>

                    <Label
                        Grid.Column="1"
                        Text="Escanear código"
                        TextColor="White"
                        FontSize="16"
                        VerticalOptions="Center"/>

                </Grid>

                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="EscanearCodigo"/>
                </Frame.GestureRecognizers>

            </Frame>

            <!-- FOTO -->
            <Image
                x:Name="FotoPreview"
                HeightRequest="200"
                BackgroundColor="#EEEEEE"/>

            <!-- 📸 BOTON FOTO CON ICONO -->
            <Frame
                CornerRadius="20"
                BackgroundColor="#0D3B66"
                Padding="15"
                HasShadow="False">

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">

                    <Image
                        Source="fotofix.png"
                        HeightRequest="26"
                        WidthRequest="26"
                        VerticalOptions="Center"/>

                    <Label
                        Grid.Column="1"
                        Text="Tomar fotografía (obligatoria)"
                        TextColor="White"
                        FontSize="16"
                        VerticalOptions="Center"/>

                </Grid>

                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="TomarFoto"/>
                </Frame.GestureRecognizers>

            </Frame>

            <!-- COMENTARIOS -->
            <Editor
                x:Name="ComentarioEditor"
                Placeholder="Describe el daño..."
                HeightRequest="120"
                BackgroundColor="#F5F5F5"/>

            <!-- GUARDAR (lo dejamos igual) -->
            <Button
                Text="Guardar reporte"
                BackgroundColor="#2E7D32"
                TextColor="White"
                Clicked="GuardarReporte"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>