<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="MejoraFixturesNortesV2.Views.DevolverFixturePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="White"
    NavigationPage.HasNavigationBar="False">

    <ScrollView>

        <VerticalStackLayout Padding="25" Spacing="20">

            <!-- TITULO -->
            <Label
                Text="Mis Fixtures en uso"
                FontSize="26"
                FontAttributes="Bold"
                TextColor="#0D3B66"/>

            <!-- TARJETA FIXTURE -->
            <Frame
                x:Name="FixtureCard"
                CornerRadius="18"
                Padding="20"
                BackgroundColor="White"
                BorderColor="#E5E5E5"
                HasShadow="True">

                <Grid ColumnDefinitions="90,*">

                    <!-- IMAGEN -->
                    <Image
                        Source="fixture1.png"
                        HeightRequest="80"
                        WidthRequest="80"/>

                    <!-- INFORMACION -->
                    <VerticalStackLayout Grid.Column="1" Spacing="5">

                        <Label
                            Text="Serial"
                            FontSize="13"
                            TextColor="Gray"/>

                        <Label
                            x:Name="SerialLabel"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#0D3B66"/>

                        <Label
                            x:Name="ProcesoLabel"
                            FontSize="14"
                            TextColor="Gray"/>

                        <!-- ESTADO -->
                        <Label
                            x:Name="EstadoLabel"
                            Padding="8,3"
                            TextColor="White"
                            FontSize="12"
                            HorizontalOptions="Start"/>

                        <Label
                            x:Name="ResponsableLabel"
                            FontSize="14"
                            TextColor="#0D3B66"/>

                    </VerticalStackLayout>

                </Grid>

            </Frame>

            <!-- ADVERTENCIA WINDOWS -->
            <Frame
                BackgroundColor="#FFF3CD"
                CornerRadius="12"
                Padding="15">

                <HorizontalStackLayout Spacing="10">

                    <Image
                        Source="emergency.png"
                        HeightRequest="24"/>

                    <Label
                        Text="La cámara solo está disponible en dispositivos móviles."
                        FontSize="13"
                        TextColor="#856404"
                        VerticalOptions="Center"/>

                </HorizontalStackLayout>

            </Frame>

            <!-- FOTO -->
            <Button
                Text="Tomar fotografía (obligatoria)"
                ImageSource="fotofix.png"
                BackgroundColor="#0D3B66"
                TextColor="White"
                CornerRadius="14"
                HeightRequest="60"
                Clicked="TomarFoto"/>

            <!-- OBSERVACIONES -->
            <Editor
                x:Name="ObservacionesEntry"
                Placeholder="Observaciones (opcional)"
                AutoSize="TextChanges"
                HeightRequest="120"
                BackgroundColor="#F4F4F4"/>

            <!-- BOTON DEVOLVER -->
            <Button
                x:Name="ConfirmarButton"
                Text="Confirmar devolución"
                BackgroundColor="#2E7D32"
                TextColor="White"
                CornerRadius="14"
                HeightRequest="60"
                Clicked="ConfirmarDevolucion"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>