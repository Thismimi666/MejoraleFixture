<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="MejoraFixturesNortesV2.Views.DevolverFixturePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="White"
    NavigationPage.HasNavigationBar="False">

    <ScrollView>

        <VerticalStackLayout Padding="25" Spacing="20">

            <!--  TITULO  -->
            <Grid Margin="10,30,20,10" ColumnDefinitions="Auto,*">

                <Border
                    Padding="10,6"
                    Stroke="#0D3B66"
                    StrokeThickness="1.5"
                    VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="VolverButton_Clicked" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="4">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="&#x2039;"
                            TextColor="#0D3B66"
                            VerticalOptions="Center" />
                        <Label
                            FontSize="14"
                            Text="Volver"
                            TextColor="#0D3B66"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
                <Label
                    Grid.Column="1"
                    FontAttributes="Bold"
                    FontSize="26"
                    Text="Mis Fixtures en uso"
                    TextColor="#0D3B66" />
            </Grid>

            <!--  TARJETA FIXTURE  -->
            <Frame
                x:Name="FixtureCard"
                Padding="20"
                BackgroundColor="White"
                BorderColor="#E5E5E5"
                CornerRadius="18"
                HasShadow="True">

                <Grid ColumnDefinitions="90,*">

                    <!--  IMAGEN  -->
                    <Image
                        HeightRequest="80"
                        Source="fixture1.png"
                        WidthRequest="80" />

                    <!--  INFORMACION  -->
                    <VerticalStackLayout Grid.Column="1" Spacing="5">

                        <Label
                            FontSize="13"
                            Text="Serial"
                            TextColor="Gray" />

                        <Label
                            x:Name="SerialLabel"
                            FontAttributes="Bold"
                            FontSize="20"
                            TextColor="#0D3B66" />

                        <Label
                            x:Name="ProcesoLabel"
                            FontSize="14"
                            TextColor="Gray" />

                        <!--  ESTADO  -->
                        <Label
                            x:Name="EstadoLabel"
                            Padding="8,3"
                            FontSize="12"
                            HorizontalOptions="Start"
                            TextColor="White" />

                        <Label
                            x:Name="ResponsableLabel"
                            FontSize="14"
                            TextColor="#0D3B66" />

                    </VerticalStackLayout>

                </Grid>

            </Frame>

            <!--  ADVERTENCIA WINDOWS  -->
            <Frame
                Padding="15"
                BackgroundColor="#FFF3CD"
                CornerRadius="12">

                <HorizontalStackLayout Spacing="10">

                    <Image HeightRequest="24" Source="emergency.png" />

                    <Label
                        FontSize="13"
                        Text="La cámara solo está disponible en dispositivos móviles."
                        TextColor="#856404"
                        VerticalOptions="Center" />

                </HorizontalStackLayout>

            </Frame>

            <!--  FOTO  -->
            <Button
                BackgroundColor="#0D3B66"
                Clicked="TomarFoto"
                CornerRadius="14"
                HeightRequest="60"
                ImageSource="fotofix.png"
                Text="Tomar fotografía (obligatoria)"
                TextColor="White" />

            <!--  OBSERVACIONES  -->
            <Editor
                x:Name="ObservacionesEntry"
                AutoSize="TextChanges"
                BackgroundColor="#F4F4F4"
                HeightRequest="120"
                Placeholder="Observaciones (opcional)" />

            <!--  BOTON DEVOLVER  -->
            <Button
                x:Name="ConfirmarButton"
                BackgroundColor="#2E7D32"
                Clicked="ConfirmarDevolucion"
                CornerRadius="14"
                HeightRequest="60"
                Text="Confirmar devolución"
                TextColor="White" />

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>
