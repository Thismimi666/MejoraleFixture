<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MejoraFixturesNortesV2.Views.NotasAdminPage"
    BackgroundColor="#0D3B66">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER -->
        <StackLayout Padding="20" Spacing="10">

            <Grid>
                <Label Text="Notas Admin"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"/>

                <!-- BOTÓN AGREGAR -->
                <ImageButton Source="agregar.png"
                             HeightRequest="40"
                             WidthRequest="40"
                             BackgroundColor="Transparent"
                             HorizontalOptions="End"
                             Clicked="OnAgregarClicked"/>
            </Grid>

            <Label Text="Consejos y recordatorios para evitar defectos en fixtures"
                   FontSize="13"
                   TextColor="#D6E4F0"
                   HorizontalTextAlignment="Center"/>
        </StackLayout>

        <!-- LISTA DE NOTAS -->
        <CollectionView Grid.Row="1"
                        x:Name="NotasList"
                        Margin="15">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame CornerRadius="15"
                           Padding="15"
                           Margin="0,8"
                           BackgroundColor="White">

                        <Grid ColumnDefinitions="*,Auto">

                            <!-- TEXTO -->
                            <StackLayout Spacing="5">
                                <Label Text="{Binding Titulo}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#0D3B66"/>

                                <Label Text="{Binding Descripcion}"
                                       FontSize="13"
                                       TextColor="#333"/>
                            </StackLayout>

                            <!-- BOTÓN ELIMINAR -->
                            <Button Text="Eliminar"
                                    Grid.Column="1"
                                    BackgroundColor="#E74C3C"
                                    TextColor="White"
                                    CornerRadius="10"
                                    HeightRequest="35"
                                    Clicked="OnEliminarClicked"
                                    CommandParameter="{Binding .}"/>

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- FOOTER -->
        <Grid Grid.Row="2" Padding="15">
            <Button Text="Cerrar sesión"
                    ImageSource="sesion.png"
                    BackgroundColor="White"
                    TextColor="#0D3B66"
                    CornerRadius="20"
                    HeightRequest="50"
                    Clicked="OnCerrarSesionClicked"/>
        </Grid>

    </Grid>

</ContentPage>