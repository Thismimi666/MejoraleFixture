<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MejoraFixturesNortesV2.Views.SolicitarFixturePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="White"
    NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!--  TITULO  -->
        <Grid Margin="10,30,20,10" ColumnDefinitions="Auto,*">

            <Border
                Padding="10,6"
                Stroke="#0D3B66"
                StrokeThickness="1.5"
                VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="VolverButton_Clicked" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="4">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="&#x2039;"
                        TextColor="#0D3B66"
                        VerticalOptions="Center" />
                    <Label
                        FontSize="14"
                        Text="Volver"
                        TextColor="#0D3B66"
                        VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

            <Label
                Grid.Column="1"
                Margin="12,0,0,0"
                FontAttributes="Bold"
                FontSize="28"
                Text="Solicitar Fixture"
                TextColor="#0D3B66"
                VerticalOptions="Center" />
        </Grid>

        <!--  TARJETA FIXTURE  -->
        <Frame
            x:Name="FixtureCard"
            Grid.Row="1"
            Margin="20"
            Padding="20"
            BackgroundColor="White"
            BorderColor="#E6E6E6"
            CornerRadius="15"
            IsVisible="False">

            <Grid ColumnDefinitions="90,*">

                <Image
                    HeightRequest="80"
                    Source="fixture1.png"
                    WidthRequest="80" />

                <VerticalStackLayout Grid.Column="1">

                    <Label
                        x:Name="SerialLabel"
                        FontAttributes="Bold"
                        FontSize="22"
                        TextColor="#0D3B66" />

                    <Label
                        x:Name="ProcesoLabel"
                        FontSize="14"
                        TextColor="Gray" />

                    <Label
                        x:Name="EstadoLabel"
                        Padding="8,3"
                        FontSize="12"
                        HorizontalOptions="Start"
                        TextColor="White" />

                </VerticalStackLayout>

            </Grid>

        </Frame>

        <!--  BOTONES  -->
        <VerticalStackLayout
            Grid.Row="2"
            Margin="20"
            Spacing="15">

            <Button
                BackgroundColor="#0D3B66"
                Clicked="EscanearCodigo"
                CornerRadius="12"
                HeightRequest="55"
                ImageSource="elescaneo.png"
                Text="Escanear código"
                TextColor="White" />

            <Button
                BackgroundColor="#0D3B66"
                Clicked="TomarFoto"
                CornerRadius="12"
                HeightRequest="55"
                ImageSource="fotofix.png"
                Text="Tomar fotografía"
                TextColor="White" />

            <Entry
                x:Name="UsuarioEntry"
                BackgroundColor="#F4F4F4"
                Placeholder="Nombre del usuario"
                TextColor="#0D3B66" />

        </VerticalStackLayout>

        <!--  CONFIRMAR  -->
        <Button
            x:Name="ConfirmarButton"
            Grid.Row="3"
            Margin="20"
            BackgroundColor="#2E7D32"
            Clicked="ConfirmarSolicitud"
            CornerRadius="12"
            HeightRequest="55"
            IsEnabled="False"
            Text="Confirmar solicitud"
            TextColor="White" />

        <!--  MENSAJE WINDOWS  -->
        <Frame
            Grid.Row="4"
            Margin="20"
            Padding="15"
            BackgroundColor="#F4F4F4"
            CornerRadius="12">

            <HorizontalStackLayout Spacing="10">

                <Image HeightRequest="25" Source="emergency.png" />

                <Label
                    Text="El escaneo y la fotografía sólo están disponibles en dispositivos Android."
                    TextColor="#333"
                    VerticalOptions="Center" />

            </HorizontalStackLayout>

        </Frame>

    </Grid>

</ContentPage>
