<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MejoraFixturesNortesV2.Views.CambiarPasswordPage"
    BackgroundColor="#0D3B66"
    NavigationPage.HasNavigationBar="False">

    <Grid>

        <!-- CONTENEDOR CENTRAL -->
        <VerticalStackLayout
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Padding="20"
            MaximumWidthRequest="420">

            <!-- TARJETA -->
            <Frame BackgroundColor="White"
                   CornerRadius="22"
                   Padding="30"
                   HasShadow="True">

                <VerticalStackLayout Spacing="18">

                    <!-- ICONO -->
                    <Image Source="secretoicono.png"
                           HeightRequest="70"
                           HorizontalOptions="Center"/>

                    <!-- TITULO -->
                    <Label Text="Cambio obligatorio de contraseña"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#0D3B66"
                           HorizontalOptions="Center"/>

                    <!-- MENSAJE -->
                    <Frame BackgroundColor="#F4F6F8"
                           CornerRadius="12"
                           Padding="10">

                        <Label Text="Está utilizando una contraseña temporal. Debe actualizarla para continuar."
                               FontSize="13"
                               TextColor="Gray"/>
                    </Frame>

                    <!-- NUEVA CONTRASEÑA -->
                    <Grid ColumnDefinitions="*,40">

                        <Entry x:Name="NuevaPasswordEntry"
                               Placeholder="Nueva contraseña"
                               IsPassword="True"
                               BackgroundColor="#F2F2F2"
                               TextColor="Black"/>

                        <ImageButton Grid.Column="1"
                                     Source="novisible.png"
                                     Clicked="OnToggleNuevaPassword"
                                     BackgroundColor="Transparent"/>

                    </Grid>

                    <!-- CONFIRMAR CONTRASEÑA -->
                    <Grid ColumnDefinitions="*,40">

                        <Entry x:Name="ConfirmarPasswordEntry"
                               Placeholder="Confirmar contraseña"
                               IsPassword="True"
                               BackgroundColor="#F2F2F2"
                               TextColor="Black"/>

                        <ImageButton Grid.Column="1"
                                     Source="novisible.png"
                                     Clicked="OnToggleConfirmarPassword"
                                     BackgroundColor="Transparent"/>

                    </Grid>

                    <!-- REGLAS -->
                    <Frame BackgroundColor="#F4F6F8"
                           CornerRadius="12"
                           Padding="12">

                        <VerticalStackLayout Spacing="4">

                            <Label Text="La contraseña debe contener:"
                                   FontAttributes="Bold"
                                   FontSize="12"/>

                            <Label Text="• Mínimo 8 caracteres" FontSize="12"/>
                            <Label Text="• 1 mayúscula y 1 minúscula" FontSize="12"/>
                            <Label Text="• 1 número" FontSize="12"/>
                            <Label Text="• 1 símbolo" FontSize="12"/>

                        </VerticalStackLayout>

                    </Frame>

                    <!-- BOTON ACTUALIZAR -->
                    <Button Text="Actualizar contraseña"
                            BackgroundColor="#0D3B66"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="50"
                            Clicked="OnActualizarPassword"/>

                    <!-- VOLVER -->
                    <Button Text="Volver al login"
                            BackgroundColor="White"
                            TextColor="#0D3B66"
                            BorderColor="#0D3B66"
                            BorderWidth="2"
                            CornerRadius="12"
                            HeightRequest="45"
                            Clicked="OnVolverLogin"/>

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>

    </Grid>

</ContentPage>